NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Demo mode ─────────────────────────────────────────────────────────────────
# true  = use local demo data (no backend needed)
# false = use live backend API
USE_DEMO_DATA=true
NEXT_PUBLIC_WHATSAPP_NUMBER=94770000000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── hCaptcha ──────────────────────────────────────────────────────────────────
# Get your keys from https://www.hcaptcha.com (free tier available)
# Public site key — safe to put in browser
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
# Secret key — SERVER ONLY, never commit the real value
HCAPTCHA_SECRET=your_hcaptcha_secret_key

# ── Email notification (SERVER ONLY — no NEXT_PUBLIC_ prefix) ─────────────────
# The email address that receives every contact form submission
NOTIFY_EMAIL=admin@ceylontrailer.com

# Zoho Mail SMTP — use your Zoho email address and App Password
# Create an App Password at: https://accounts.zoho.com/home#security (Two-Factor Auth → App Passwords)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-zoho-app-password
